generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Shift {
  A
  B
  C
  D
}

model ShiftSession {
  id        Int       @id @default(autoincrement())
  shift     Shift
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  machines  Machine[]
  createdAt DateTime  @default(now())
}

model Machine {
  id        String @id @default(cuid())
  code      String
  material  String
  frequency Float  @default(1)
  firstTest String
  shift     Shift

  shiftSessionId Int
  shiftSession   ShiftSession @relation(fields: [shiftSessionId], references: [id])

  stops Stop[]
  tests Test[]

  createdAt DateTime @default(now())

  @@unique([code, shiftSessionId])
  @@index([shiftSessionId])
}

model Stop {
  id         Int      @id @default(autoincrement())
  machineId  String
  machine    Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  stopTime   String
  reason     String
  resumeTime String?
  createdAt  DateTime @default(now())

  @@index([machineId])
}

model Test {
  id        Int      @id @default(autoincrement())
  machineId String
  machine   Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  testTime  String
  createdAt DateTime @default(now())

  @@index([machineId])
}
