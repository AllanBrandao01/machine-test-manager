generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ShiftSession {
  id        Int       @id @default(autoincrement())
  shift     String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  machines  Machine[]
  createdAt DateTime  @default(now())
}

model Machine {
  id        String @id @default(cuid())
  code      String
  material  String
  frequency Float
  firstTest String
  shift     String

  shiftSessionId Int?
  shiftSession   ShiftSession? @relation(fields: [shiftSessionId], references: [id])

  stops Stop[]
  tests Test[]

  createdAt DateTime @default(now())
}

model Stop {
  id         Int      @id @default(autoincrement())
  machineId  String
  machine    Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  stopTime   String
  reason     String
  resumeTime String?
  createdAt  DateTime @default(now())
}

model Test {
  id        Int      @id @default(autoincrement())
  machineId String
  machine   Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  testTime  String
  createdAt DateTime @default(now())
}
